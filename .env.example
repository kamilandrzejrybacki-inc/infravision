# Required: NetBox
NETBOX_URL=http://your-netbox:8081
NETBOX_TOKEN=your-netbox-api-token

# Required: Domain for quickLinks
INFRA_DOMAIN=your-domain.example.com

# Required: Path to Ansible repo
ANSIBLE_PATH=/path/to/ansible

# Optional: ArgoCD (live API for K8s service discovery)
ARGOCD_URL=http://your-k8s-node:30080
ARGOCD_PASSWORD=your-argocd-admin-password

# Optional: Grafana (enables dashboard link enrichment)
GRAFANA_URL=http://your-grafana:3000
GRAFANA_TOKEN=your-grafana-service-account-token
